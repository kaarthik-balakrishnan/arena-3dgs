{
  "cells": [
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "# 3D Gaussian Splatting - Google Colab\n",
        "\n",
        "This notebook runs 3D Gaussian Splatting on Google Colab to reconstruct a 3D point cloud from images.\n",
        "\n",
        "## Setup"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "#@title Install Dependencies\n",
        "%cd /content\n",
        "\n",
        "# Install COLMAP\n",
        "!apt-get update\n",
        "!apt-get install -y colmap\n",
        "\n",
        "# Install PyTorch with CUDA\n",
        "!pip install torch==2.1.0 torchvision==0.16.0 --index-url https://download.pytorch.org/whl/cu118\n",
        "\n",
        "# Install required packages\n",
        "!pip install plyfile numpy pillow opencv-python-headless tqdm"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "#@title Clone and Setup 3D Gaussian Splatting\n",
        "%cd /content\n",
        "\n",
        "# Clone the official 3DGS repository\n",
        "!git clone --recursive https://github.com/graphdeco-inria/gaussian-splatting\n",
        "%cd /content/gaussian-splatting\n",
        "\n",
        "# Install submodules\n",
        "!pip install ./submodules/diff-gaussian-rasterization\n",
        "!pip install ./submodules/simple-knn"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "#@title Upload Images\n",
        "from google.colab import files\n",
        "import os\n",
        "\n",
        "# Create input directory\n",
        "!mkdir -p /content/gaussian-splatting/input_images\n",
        "\n",
        "# Upload zip file containing images\n",
        "uploaded = files.upload()\n",
        "\n",
        "# Extract if it's a zip\n",
        "for fname in uploaded.keys():\n",
        "    if fname.endswith('.zip'):\n",
        "        !unzip -q {fname} -d /content/gaussian-splatting/input_images\n",
        "    elif os.path.isdir(fname):\n",
        "        !mv {fname}/* /content/gaussian-splatting/input_images/\n",
        "\n",
        "# Count images\n",
        "!ls /content/gaussian-splatting/input_images | wc -l"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "#@title Run Structure from Motion (COLMAP)\n",
        "%cd /content/gaussian-splatting\n",
        "\n",
        "input_path = \"/content/gaussian-splatting/input_images\"\",
        "output_path = \"/content/gaussian-splatting/output/sparse\"\n",
        "\n",
        "!mkdir -p {output_path}\n",
        "\n",
        "# Run COLMAP feature extraction\n",
        "!colmap feature_extractor \\\n",
        "    --database_path {output_path}/database.db \\\n",
        "    --image_path {input_path} \\\n",
        "    --SiftExtraction.estimate_abundance_normalization 0 \\\n",
        "    --SiftExtraction.normalization 1\n",
        "\n",
        "# Run COLMAP matcher\n",
        "!colmap exhaustive_matcher \\\n",
        "    --database_path {output_path}/database.db \\\n",
        "    --SiftMatching.estimate_abundance_normalization 0 \\\n",
        "    --SiftMatching.normalization 1\n",
        "\n",
        "# Run COLMAP mapper\n",
        "!colmap mapper \\\n",
        "    --database_path {output_path}/database.db \\\n",
        "    --image_path {input_path} \\\n",
        "    --output_path {output_path}\n",
        "\n",
        "# Check if sparse reconstruction was successful\n",
        "!ls -la {output_path}/0/"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "#@title Convert COLMAP to Gaussian Splatting Format\n",
        "%cd /content/gaussian-splatting\n",
        "\n",
        "# Create output directory structure\n",
        "!mkdir -p output/train\n",
        "\n",
        "# Run the conversion script\n",
        "!python convert.py \\\n",
        "    --source_path /content/gaussian-splatting/input_images \\\n",
        "    --model_path /content/gaussian-splatting/output/sparse/0 \\\n",
        "    --output_path /content/gaussian-splatting/output/train"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "#@title Train Gaussian Splatting Model\n",
        "%cd /content/gaussian-splatting\n",
        "\n",
        "# Train for 3000 iterations (adjust for quality)\n",
        "!python train.py \\\n",
        "    -s /content/gaussian-splatting/output/train \\\n",
        "    -i 0 \\\n",
        "    --iterations 3000 \\\n",
        "    --checkpoint 1000"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "#@title Extract Point Cloud from Trained Model\n",
        "import numpy as np\n",
        "from plyfile import PlyData, PlyElement\n",
        "import os\n",
        "\n",
        "# Path to trained model\n",
        "model_path = \"/content/gaussian-splatting/output/train/point_cloud/iteration_3000\"\n",
        "\n",
        "# Load the point cloud from .ply file if exists\n",
        "ply_path = None\n",
        "for f in os.listdir(model_path):\n",
        "    if f.endswith('.ply'):\n",
        "        ply_path = os.path.join(model_path, f)\n",
        "        break\n",
        "\n",
        "if ply_path:\n",
        "    print(f\"Point cloud found at: {ply_path}\")\n",
        "    # Copy to output\n",
        "    !cp {ply_path} /content/arena_point_cloud.ply\n",
        "    \n",
        "    # Also extract from the checkpoints\n",
        "    print(\"\\nPoint cloud saved to /content/arena_point_cloud.ply\")\n",
        "    !ls -lh /content/arena_point_cloud.ply\n",
        "else:\n",
        "    print(\"No .ply file found, checking checkpoint files...\")\n",
        "    !ls {model_path}"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "#@title Download Point Cloud\n",
        "from google.colab import files\n",
        "\n",
        "# Download the point cloud\n",
        "files.download('/content/arena_point_cloud.ply')\n",
        "\n",
        "# Also download the full model\n",
        "!zip -r /content/gaussian_splatting_model.zip /content/gaussian-splatting/output/train\n",
        "files.download('/content/gaussian_splatting_model.zip')"
      ]
    }
  ],
